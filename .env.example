# FIE server configuration — copy to .env and fill in real values.
# NEVER commit .env. All values here are placeholders.

# ── Required ──────────────────────────────────────────────────────────────
# MongoDB Atlas (free tier works): https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB_NAME=fie_database

# Groq API key (free): https://console.groq.com — powers the shadow ensemble
GROQ_API_KEY=gsk_your_groq_key
GROQ_ENABLED=true

# JWT signing secret — generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

# Email that receives the admin role on first login
ADMIN_EMAIL=you@example.com

# ── Google OAuth (dashboard login) ────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/login

# ── Optional ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed dashboard origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Static API key accepted even when MongoDB is down (also used by
# tests/stress_test_suite.py). Generate like the JWT secret above.
#FIE_API_KEY=fie-local-dev-key

# Serper (real-time Google search for temporal ground truth): https://serper.dev
#SERPER_API_KEY=your-serper-key
#SERPER_ENABLED=true

# SendGrid email alerts: https://sendgrid.com
#SENDGRID_API_KEY=SG.your-sendgrid-key
#NOTIFICATION_EMAIL=alerts@example.com

# Sentry error tracking (free tier: https://sentry.io) — off unless set
#SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Stage UNCERTAIN-zone blocks for PAIR retraining review
#FIE_COLLECT_HARD_POSITIVES=1

# Redis-backed rate limiting (defaults to in-memory when unset)
#REDIS_URL=redis://localhost:6379/0

DEBUG=false
