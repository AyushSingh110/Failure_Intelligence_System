# FIE dashboard configuration — copy to .env.local and fill in real values.
# Vite only exposes variables prefixed with VITE_.

# FastAPI backend base URL (include /api/v1)
VITE_API_URL=http://localhost:8000/api/v1

# Google OAuth client ID — must match GOOGLE_CLIENT_ID in the backend .env,
# and http://localhost:5173/login must be an authorized redirect URI.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
